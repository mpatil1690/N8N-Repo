    {
      "parameters": {
        "jsCode": "/**\n * n8n Code node: Resolve company URL\n */\nconst items = $input.all();\nconst out = [];\nconst COMPANY_PREFIX = 'https://www.linkedin.com/company/';\n\nfunction extractHandle(urlOrHandle) {\n  if (!urlOrHandle || typeof urlOrHandle !== 'string') return '';\n  const s = urlOrHandle.trim().replace(/^company\\//i, '');\n  const match = s.match(/linkedin\\.com\\/company\\/([^/?&#]+)/i);\n  return match ? match[1] : s;\n}\n\nfor (const item of items) {\n  const j = item.json;\n  const linkedInPage = (j['LinkedIn Company Page'] || j['Linkedin Company Page'] || '').toString().trim();\n  const handleCol = (j['Linkedin handle'] || j['LinkedIn handle'] || '').toString().trim().replace(/^company\\//i, '');\n  let companyUrl = '';\n  let skip = true;\n\n  if (linkedInPage && linkedInPage.toLowerCase().includes('linkedin.com')) {\n    const h = extractHandle(linkedInPage);\n    companyUrl = h ? COMPANY_PREFIX + h : linkedInPage;\n    skip = false;\n  } else if (handleCol) {\n    companyUrl = COMPANY_PREFIX + handleCol;\n    skip = false;\n  }\n\n  if (companyUrl && !companyUrl.startsWith(COMPANY_PREFIX)) {\n    const h = extractHandle(companyUrl);\n    if (h) companyUrl = COMPANY_PREFIX + h;\n  }\n\n  out.push({ json: { ...j, companyUrl, skip } });\n}\n\nreturn out;\n"
      },
