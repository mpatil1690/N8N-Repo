    {
      "parameters": {
        "jsCode": "\nconst items = $input.all();\nconst runnable = [];\nconst pending = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const j = items[i].json;\n  const status = (j.Status || j.status || '').toString().trim().toLowerCase();\n\n  // Skip rows already completed\n  if (status.includes('done') || status.includes('skipped')) continue;\n\n  const rowIndex = i + 2;\n  const row = { json: { ...j, __rowIndex: rowIndex } };\n\n  // If you set Status = RUN in the sheet, we will process that company next\n  if (status === 'run' || status === 'run now') runnable.push(row);\n  else pending.push(row);\n}\n\nif (runnable.length) return [runnable[0]];\nif (pending.length) return [pending[0]];\nreturn [];\n"
      },
