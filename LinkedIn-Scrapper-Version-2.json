    {
      "parameters": {
        "jsCode": "/**\n * Build one result row for the Results sheet\n */\nconst staticData = $getWorkflowStaticData('global');\nconst profile = staticData.currentProfile || {};\nconst detail = $input.first().json;\n\nconst email = detail && (detail.email || detail.emails)\n  ? (detail.email || (Array.isArray(detail.emails) ? detail.emails[0] : detail.emails))\n  : '';\nconst emailStr = typeof email === 'string' ? email : (email && email.value) || '';\nconst today = new Date().toISOString().split('T')[0];\n\nlet title = (profile.title || '').toString().trim();\nif (!title && detail) {\n  const d = detail;\n  title = (d.headline || d.title || d.position || '').toString().trim();\n  if (!title && Array.isArray(d.experience) && d.experience.length > 0) {\n    const first = d.experience[0];\n    title = (first.title || first.position || first.headline || '').toString().trim();\n  }\n  if (!title && Array.isArray(d.positions) && d.positions.length > 0) {\n    const first = d.positions[0];\n    title = (first.title || first.position || first.name || '').toString().trim();\n  }\n}\n\nreturn [{\n  json: {\n    'Company Name': profile.companyName,\n    'Website URL': profile.websiteUrl,\n    'City': profile.city,\n    'Country/Region': profile.countryRegion,\n    'Industry': profile.industry,\n    'LinkedIn Company Page': profile.linkedInCompanyPage,\n    'Executive Name': profile.executiveName,\n    'Title': title || '',\n    'LinkedIn Profile URL': profile.linkedinProfileUrl,\n    'Email': emailStr || '',\n    'Date Found': today,\n  },\n}];\n"
      },
