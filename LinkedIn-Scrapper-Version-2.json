    {
      "parameters": {
        "jsCode": "/**\n * Post-filter profiles by title and attach company to each\n */\nconst staticData = $getWorkflowStaticData('global');\nconst company = staticData.currentCompany || {};\nconst raw = $input.all();\n\nlet profiles = raw;\nif (raw.length === 1 && raw[0].json) {\n  const j = raw[0].json;\n  if (Array.isArray(j)) {\n    profiles = j.map(el => ({ json: el }));\n  } else if (j.elements || j.data || j.items) {\n    const arr = j.elements || j.data || j.items;\n    profiles = Array.isArray(arr) ? arr.map(el => ({ json: el })) : raw;\n  }\n}\n\n// Tight title matching: only real CTO/CIO/CISO (not \"office of\", \"assistant to\", \"consultant\", etc.)\nconst include = [\n  /\\bcto\\b/i,\n  /\\bchief\\s+technology\\s+officer\\b/i,\n  /\\bcio\\b/i,\n  /\\bchief\\s+information\\s+officer\\b/i,\n  /\\bciso\\b/i,\n  /\\bchief\\s+information\\s+security\\s+officer\\b/i,\n];\n\nconst exclude = [\n  /\\bchief\\s+of\\s+staff\\b/i,\n  /\\boffice\\s+of\\b/i,\n  /\\bassistant\\s+to\\b/i,\n  /\\bexecutive\\s+assistant\\b/i,\n  /\\bsecretary\\b/i,\n  /\\bconsultant\\b/i,\n  /\\badvisor\\b/i,\n  /\\badvisory\\b/i,\n  /\\bto\\s+the\\b/i,\n];\n\nfunction matchesTargetTitle(title) {\n  const t = (title || '').toString().trim();\n  if (!t) return false;\n  if (exclude.some((rx) => rx.test(t))) return false;\n  return include.some((rx) => rx.test(t));\n}\n\nconst out = [];\n\nfor (const p of profiles) {\n  const j = p.json || p;\n  const titleRaw = (j.position || j.headline || j.title || '').toString().trim();\n  if (!matchesTargetTitle(titleRaw)) continue;\n\n  const name = (j.name || [j.firstName, j.lastName].filter(Boolean).join(' ').trim() || '').toString().trim();\n  let url = (j.linkedinUrl || j.profileUrl || j.url || (j.publicIdentifier ? 'https://www.linkedin.com/in/' + j.publicIdentifier : '') || '').toString().trim();\n  if (url && url.includes('linkedin.com/sales/')) url = '';\n  if (!url) continue;\n\n  out.push({\n    json: {\n      companyName: company['Company name'] || company['Company Name'] || '',\n      websiteUrl: company['Website URL'] || '',\n      city: company['City'] || '',\n      countryRegion: company['Country/Region'] || company['Country'] || '',\n      industry: company['Industry'] || '',\n      linkedInCompanyPage: company.companyUrl || company['LinkedIn Company Page'] || '',\n      executiveName: name,\n      title: titleRaw,\n      linkedinProfileUrl: url,\n    },\n  });\n}\n\nreturn out;\n"
      },
